<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:PoePerfect.Player.Android"
             xmlns:models="clr-namespace:PoePerfect.Player.Core.Models;assembly=PoePerfect.Player.Core"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="PoePerfect.Player.Android.MainPage"
             x:DataType="local:MainPage"
             Title="PoePerfect Player"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#020617">

    <Grid Padding="12"
          RowDefinitions="Auto,*"
          RowSpacing="6">
        <Border Grid.Row="0"
                Padding="8,6"
                BackgroundColor="#091223"
                Stroke="#182A45"
                StrokeShape="RoundRectangle 16">
            <Grid ColumnDefinitions="Auto,*,Auto"
                  ColumnSpacing="8">
                <Button Text="Hem"
                        Clicked="OnBackToDashboardClicked"
                        IsVisible="{Binding ShowBrowserShell}"
                        WidthRequest="58"
                        HeightRequest="38"
                        Padding="0"
                        CornerRadius="12"
                        FontSize="14"
                        VerticalOptions="Center"
                        BackgroundColor="#0F172A"
                        BorderColor="#334155"
                        BorderWidth="1"
                        TextColor="#E2E8F0" />

                <VerticalStackLayout Grid.Column="1"
                                     Spacing="2">
                    <Label Text="{Binding HeaderTitle}"
                           FontSize="18"
                           FontAttributes="Bold"
                           LineBreakMode="TailTruncation"
                           TextColor="#F8FAFC" />
                    <Label Text="{Binding HeaderSubtitle}"
                           FontSize="11"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"
                           TextColor="#8EA3BF" />
                </VerticalStackLayout>

                <Button Grid.Column="2"
                        Text="Playlists"
                        Clicked="OnOpenPlaylistEditorClicked"
                        IsVisible="{Binding ShowDashboard}"
                        WidthRequest="96"
                        HeightRequest="38"
                        Padding="0"
                        CornerRadius="12"
                        FontSize="14"
                        VerticalOptions="Center"
                        BackgroundColor="#0F172A"
                        BorderColor="#334155"
                        BorderWidth="1"
                        TextColor="#E2E8F0" />
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid IsVisible="{Binding ShowDashboard}"
                  RowDefinitions="Auto,*,Auto,Auto"
                  RowSpacing="14">
                <VerticalStackLayout Grid.Row="0"
                                     Spacing="4">
                    <Label Text="Start"
                           FontSize="12"
                           TextColor="#64748B" />
                    <Label Text="{Binding DashboardHintText}"
                           FontSize="14"
                           TextColor="#E2E8F0" />
                </VerticalStackLayout>

                <Border x:Name="DashboardPlaylistEditor"
                        IsVisible="False" />

                <ScrollView Grid.Row="1">
                    <VerticalStackLayout Spacing="14">
                        <Grid>
                            <Border Padding="22"
                                    StrokeShape="RoundRectangle 26">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#72E4E6" Offset="0" />
                                        <GradientStop Color="#4E87D9" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <VerticalStackLayout Spacing="12">
                                    <Border Padding="10,4"
                                            HorizontalOptions="Start"
                                            BackgroundColor="#16040B16"
                                            Stroke="#52FFFFFF"
                                            StrokeShape="RoundRectangle 999">
                                        <Label Text="Direkt och kanaler"
                                               FontSize="10"
                                               FontAttributes="Bold"
                                               TextColor="#E0F2FE" />
                                    </Border>
                                    <Label Text="Live"
                                           FontSize="30"
                                           FontAttributes="Bold"
                                           TextColor="White" />
                                    <Label Text="{Binding LiveCardSummary}"
                                           FontSize="13"
                                           TextColor="#E0F2FE" />
                                </VerticalStackLayout>
                            </Border>

                            <Button Text=""
                                    Clicked="OnSectionCardClicked"
                                    CommandParameter="Live"
                                    BackgroundColor="Transparent"
                                    BorderWidth="0"
                                    Opacity="0.01"
                                    Padding="0" />
                        </Grid>

                        <Grid>
                            <Border Padding="22"
                                    StrokeShape="RoundRectangle 26">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#F87171" Offset="0" />
                                        <GradientStop Color="#F59E0B" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <VerticalStackLayout Spacing="12">
                                    <Border Padding="10,4"
                                            HorizontalOptions="Start"
                                            BackgroundColor="#160B0500"
                                            Stroke="#52FFFFFF"
                                            StrokeShape="RoundRectangle 999">
                                        <Label Text="Filmer och premiärer"
                                               FontSize="10"
                                               FontAttributes="Bold"
                                               TextColor="#FFEDD5" />
                                    </Border>
                                    <Label Text="Film"
                                           FontSize="30"
                                           FontAttributes="Bold"
                                           TextColor="White" />
                                    <Label Text="{Binding MoviesCardSummary}"
                                           FontSize="13"
                                           TextColor="#FFEDD5" />
                                </VerticalStackLayout>
                            </Border>

                            <Button Text=""
                                    Clicked="OnSectionCardClicked"
                                    CommandParameter="Movies"
                                    BackgroundColor="Transparent"
                                    BorderWidth="0"
                                    Opacity="0.01"
                                    Padding="0" />
                        </Grid>

                        <Grid>
                            <Border Padding="22"
                                    StrokeShape="RoundRectangle 26">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#A78BFA" Offset="0" />
                                        <GradientStop Color="#67B7F8" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <VerticalStackLayout Spacing="12">
                                    <Border Padding="10,4"
                                            HorizontalOptions="Start"
                                            BackgroundColor="#16040B16"
                                            Stroke="#52FFFFFF"
                                            StrokeShape="RoundRectangle 999">
                                        <Label Text="Säsonger och avsnitt"
                                               FontSize="10"
                                               FontAttributes="Bold"
                                               TextColor="#EDE9FE" />
                                    </Border>
                                    <Label Text="Serier"
                                           FontSize="30"
                                           FontAttributes="Bold"
                                           TextColor="White" />
                                    <Label Text="{Binding SeriesCardSummary}"
                                           FontSize="13"
                                           TextColor="#F5F3FF" />
                                </VerticalStackLayout>
                            </Border>

                            <Button Text=""
                                    Clicked="OnSectionCardClicked"
                                    CommandParameter="Series"
                                    BackgroundColor="Transparent"
                                    BorderWidth="0"
                                    Opacity="0.01"
                                    Padding="0" />
                        </Grid>
                    </VerticalStackLayout>
                </ScrollView>

                <VerticalStackLayout Grid.Row="2"
                                     Spacing="8"
                                     HorizontalOptions="Center"
                                     IsVisible="{Binding IsBusyLoading}">
                    <ActivityIndicator IsVisible="{Binding IsBusyLoading}"
                                       IsRunning="{Binding IsBusyLoading}"
                                       Color="#38BDF8"
                                       HeightRequest="42" />
                    <Label Text="{Binding StatusText}"
                           HorizontalTextAlignment="Center"
                           TextColor="#CBD5E1" />
                </VerticalStackLayout>

                <Grid Grid.Row="3"
                      ColumnDefinitions="*,12,*"
                      ColumnSpacing="0">
                    <Border Grid.Column="0"
                            Padding="14"
                            BackgroundColor="#04070C"
                            Stroke="#1E293B"
                            StrokeShape="RoundRectangle 16">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Playlist"
                                   FontSize="11"
                                   TextColor="#64748B" />
                            <Label Text="{Binding PlaylistCardText}"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#E2E8F0" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="2"
                            Padding="14"
                            BackgroundColor="#04070C"
                            Stroke="#1E293B"
                            StrokeShape="RoundRectangle 16">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Status"
                                   FontSize="11"
                                   TextColor="#64748B" />
                            <Label Text="{Binding StatusText}"
                                   FontSize="12"
                                   TextColor="#38BDF8" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </Grid>

            <Grid IsVisible="{Binding ShowBrowserShell}"
                  RowDefinitions="Auto,Auto,Auto,*"
                  RowSpacing="8">
                <VerticalStackLayout Grid.Row="0"
                                     Spacing="8">
                <Border x:Name="BrowserPlaylistEditor"
                        Grid.Row="0"
                        IsVisible="False"
                        Padding="14"
                        BackgroundColor="#091223"
                        Stroke="#182A45"
                        StrokeShape="RoundRectangle 18">
                    <Grid IsVisible="False"
                          RowDefinitions="Auto,Auto"
                          RowSpacing="8">
                        <Grid ColumnDefinitions="Auto,Auto,Auto,*"
                              ColumnSpacing="8">
                            <Button Text="{Binding SearchToggleButtonText}"
                                    Clicked="OnToggleSearchClicked"
                                    WidthRequest="42"
                                    HeightRequest="38"
                                    Padding="0"
                                    CornerRadius="19"
                                    BackgroundColor="#0F172A"
                                    BorderColor="#334155"
                                    BorderWidth="1"
                                    TextColor="#E2E8F0" />
                            <Button Grid.Column="1"
                                    Text="☰"
                                    IsVisible="False"
                                    Clicked="OnToggleCategoryManagerClicked"
                                    WidthRequest="42"
                                    HeightRequest="38"
                                    Padding="0"
                                    CornerRadius="19"
                                    BackgroundColor="#0F172A"
                                    BorderColor="#334155"
                                    BorderWidth="1"
                                    TextColor="#E2E8F0" />
                            <Button Grid.Column="2"
                                    Text="♥"
                                    IsVisible="False"
                                    Clicked="OnToggleFavoritesOnlyClicked"
                                    WidthRequest="42"
                                    HeightRequest="38"
                                    Padding="0"
                                    CornerRadius="19"
                                    BackgroundColor="#0F172A"
                                    BorderColor="#334155"
                                    BorderWidth="1"
                                    TextColor="#E2E8F0">
                                <Button.Triggers>
                                    <DataTrigger TargetType="Button"
                                                 Binding="{Binding FavoritesOnly}"
                                                 Value="True">
                                        <Setter Property="BackgroundColor"
                                                Value="#1A0B10" />
                                        <Setter Property="BorderColor"
                                                Value="#EF4444" />
                                        <Setter Property="TextColor"
                                                Value="#EF4444" />
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>
                        </Grid>

                        <SearchBar Grid.Row="1"
                                   IsVisible="{Binding IsSearchVisible}"
                                   Placeholder="SÃ¶k i vald sektion"
                                   Text="{Binding SearchText}"
                                   TextChanged="OnSearchTextChanged"
                                   BackgroundColor="#0F172A"
                                   TextColor="#E2E8F0"
                                   PlaceholderColor="#64748B" />
                    </Grid>

                    <VerticalStackLayout Spacing="10">
                        <Label Text="Playlist-länk"
                               FontAttributes="Bold"
                               TextColor="#E2E8F0" />
                        <Entry Placeholder="Klistra in M3U-länk"
                               Text="{Binding PlaylistSource}"
                               ClearButtonVisibility="WhileEditing"
                               Keyboard="Url"
                               TextColor="#E2E8F0"
                               PlaceholderColor="#64748B"
                               BackgroundColor="#0F172A" />
                        <HorizontalStackLayout Spacing="10">
                            <Button Text="Ladda spellista"
                                    Clicked="OnLoadPlaylistClicked"
                                    BackgroundColor="#0EA5E9"
                                    TextColor="White"
                                    HorizontalOptions="Fill" />
                            <Button Text="Stäng"
                                    Clicked="OnClosePlaylistEditorClicked"
                                    BackgroundColor="#1E293B"
                                    TextColor="#E2E8F0" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="1"
                        IsVisible="{Binding IsSearchVisible}"
                        Padding="0"
                        BackgroundColor="Transparent"
                        StrokeThickness="0">
                    <Grid RowDefinitions="Auto,Auto"
                          RowSpacing="8">
                        <Grid ColumnDefinitions="Auto,Auto,Auto,*"
                              ColumnSpacing="8">
                            <Button Text="{Binding SearchToggleButtonText}"
                                    Clicked="OnToggleSearchClicked"
                                    WidthRequest="42"
                                    HeightRequest="38"
                                    Padding="0"
                                    CornerRadius="19"
                                    BackgroundColor="#0F172A"
                                    BorderColor="#334155"
                                    BorderWidth="1"
                                    TextColor="#E2E8F0" />
                            <Button Grid.Column="1"
                                    Text="☰"
                                    IsVisible="False"
                                    Clicked="OnToggleCategoryManagerClicked"
                                    WidthRequest="42"
                                    HeightRequest="38"
                                    Padding="0"
                                    CornerRadius="19"
                                    BackgroundColor="#0F172A"
                                    BorderColor="#334155"
                                    BorderWidth="1"
                                    TextColor="#E2E8F0" />
                            <Button Grid.Column="2"
                                    Text="♥"
                                    IsVisible="False"
                                    Clicked="OnToggleFavoritesOnlyClicked"
                                    WidthRequest="42"
                                    HeightRequest="38"
                                    Padding="0"
                                    CornerRadius="19"
                                    BackgroundColor="#0F172A"
                                    BorderColor="#334155"
                                    BorderWidth="1"
                                    TextColor="#E2E8F0">
                                <Button.Triggers>
                                    <DataTrigger TargetType="Button"
                                                 Binding="{Binding FavoritesOnly}"
                                                 Value="True">
                                        <Setter Property="BackgroundColor"
                                                Value="#1A0B10" />
                                        <Setter Property="BorderColor"
                                                Value="#EF4444" />
                                        <Setter Property="TextColor"
                                                Value="#EF4444" />
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>
                        </Grid>

                        <SearchBar Grid.Row="1"
                                   IsVisible="{Binding IsSearchVisible}"
                                   Placeholder="SÃ¶k i vald sektion"
                                   Text="{Binding SearchText}"
                                   TextChanged="OnSearchTextChanged"
                                   BackgroundColor="#0F172A"
                                   TextColor="#E2E8F0"
                                   PlaceholderColor="#64748B" />
                    </Grid>

                    <VerticalStackLayout Spacing="0"
                                         IsVisible="{Binding IsSearchVisible}"
                                         HeightRequest="64"
                                         MinimumHeightRequest="0">
                        <SearchBar Placeholder="Sök i vald sektion"
                                   Text="{Binding SearchText}"
                                   TextChanged="OnSearchTextChanged"
                                   BackgroundColor="#0F172A"
                                   TextColor="#E2E8F0"
                                   PlaceholderColor="#64748B" />

                        <Grid ColumnDefinitions="*,Auto,Auto"
                              IsVisible="False"
                              HeightRequest="0"
                              ColumnSpacing="10">
                            <Label Text="{Binding BrowseHintText}"
                                   TextColor="#8EA3BF"
                                   VerticalOptions="Center" />
                            <Button Grid.Column="1"
                                    Text="{Binding CategoryManagerButtonText}"
                                    Clicked="OnToggleCategoryManagerClicked"
                                    BackgroundColor="#0F172A"
                                    BorderColor="#334155"
                                    BorderWidth="1"
                                    TextColor="#E2E8F0"
                                    Padding="12,6" />
                            <HorizontalStackLayout Grid.Column="2"
                                                   Spacing="8"
                                                   VerticalOptions="Center">
                                <Label Text="Fav"
                                       TextColor="#E2E8F0"
                                       VerticalOptions="Center" />
                                <Switch IsToggled="{Binding FavoritesOnly}"
                                        Toggled="OnFavoritesOnlyToggled" />
                            </HorizontalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="2"
                        IsVisible="{Binding IsCategoryManagerVisible}"
                        Padding="14"
                        BackgroundColor="#091223"
                        Stroke="#182A45"
                        StrokeShape="RoundRectangle 18">
                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="10">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Kategorier"
                                       FontAttributes="Bold"
                                       TextColor="#E2E8F0" />
                                <Label Text="{Binding CategoryManagerHintText}"
                                       FontSize="12"
                                       TextColor="#8EA3BF" />
                            </VerticalStackLayout>
                            <Button Grid.Column="1"
                                    Text="Stäng"
                                    Clicked="OnCloseCategoryManagerClicked"
                                    BackgroundColor="#1E293B"
                                    TextColor="#E2E8F0" />
                        </Grid>

                        <HorizontalStackLayout Spacing="8">
                            <Button Text="Visa alla"
                                    Clicked="OnShowAllCategoriesClicked"
                                    BackgroundColor="#0F172A"
                                    BorderColor="#334155"
                                    BorderWidth="1"
                                    TextColor="#E2E8F0" />
                            <Button Text="Dölj alla"
                                    Clicked="OnHideAllCategoriesClicked"
                                    BackgroundColor="#0F172A"
                                    BorderColor="#334155"
                                    BorderWidth="1"
                                    TextColor="#E2E8F0" />
                            <Button Text="Nollställ"
                                    Clicked="OnResetCategoryPreferencesClicked"
                                    BackgroundColor="#0F172A"
                                    BorderColor="#334155"
                                    BorderWidth="1"
                                    TextColor="#E2E8F0" />
                        </HorizontalStackLayout>

                        <ScrollView HeightRequest="230">
                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding CategoryManagerItems}"
                                                 Spacing="8">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="local:PlaylistCategoryManagerItem">
                                        <Border Padding="12"
                                                BackgroundColor="#0F172A"
                                                Stroke="#1E293B"
                                                StrokeShape="RoundRectangle 14">
                                            <Grid ColumnDefinitions="*,Auto,Auto,Auto"
                                                  ColumnSpacing="10">
                                                <VerticalStackLayout Spacing="2">
                                                    <Label Text="{Binding Label}"
                                                           FontAttributes="Bold"
                                                           TextColor="#E2E8F0" />
                                                    <Label Text="{Binding CountLabel}"
                                                           FontSize="12"
                                                           TextColor="#8EA3BF" />
                                                </VerticalStackLayout>

                                                <Switch Grid.Column="1"
                                                        IsToggled="{Binding IsVisible}"
                                                        Toggled="OnCategoryVisibilityToggled"
                                                        VerticalOptions="Center" />

                                                <Button Grid.Column="2"
                                                        Text="Upp"
                                                        Clicked="OnMoveCategoryUpClicked"
                                                        BackgroundColor="#1E293B"
                                                        TextColor="#E2E8F0"
                                                        VerticalOptions="Center" />

                                                <Button Grid.Column="3"
                                                        Text="Ner"
                                                        Clicked="OnMoveCategoryDownClicked"
                                                        BackgroundColor="#1E293B"
                                                        TextColor="#E2E8F0"
                                                        VerticalOptions="Center" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>
                        </ScrollView>
                    </VerticalStackLayout>
                </Border>

                </VerticalStackLayout>

                <Grid Grid.Row="1"
                      IsVisible="{Binding ShowBrowserControls}"
                      ColumnDefinitions="Auto,*"
                      ColumnSpacing="8">
                    <Button Text="{Binding SearchToggleButtonText}"
                            Clicked="OnToggleSearchClicked"
                            WidthRequest="42"
                            HeightRequest="38"
                            Padding="0"
                            CornerRadius="19"
                            BackgroundColor="#0F172A"
                            BorderColor="#334155"
                            BorderWidth="1"
                            TextColor="#E2E8F0"
                            VerticalOptions="Center" />

                    <ScrollView Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalScrollBarVisibility="Never">
                    <HorizontalStackLayout BindableLayout.ItemsSource="{Binding CategoryOptions}"
                                           Spacing="8">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="local:BrowseCategoryChip">
                                <Button Text="{Binding DisplayText}"
                                        Clicked="OnCategoryChipClicked"
                                        CommandParameter="{Binding Key}"
                                        BackgroundColor="#0F172A"
                                        BorderColor="#334155"
                                        BorderWidth="1"
                                        TextColor="#CBD5E1"
                                        Padding="14,8">
                                    <Button.Triggers>
                                        <DataTrigger TargetType="Button"
                                                     Binding="{Binding IsSelected}"
                                                     Value="True">
                                            <Setter Property="BackgroundColor"
                                                    Value="#0E7490" />
                                            <Setter Property="BorderColor"
                                                    Value="#38BDF8" />
                                            <Setter Property="TextColor"
                                                    Value="White" />
                                        </DataTrigger>
                                    </Button.Triggers>
                                </Button>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>
                    </ScrollView>
                </Grid>

                <Grid Grid.Row="2"
                      IsVisible="{Binding ShowBrowserControls}">
                    <Label Text="{Binding StatusText}"
                           TextColor="#CBD5E1"
                           VerticalOptions="Center" />
                </Grid>

                <Grid Grid.Row="3">
                    <CollectionView ItemsSource="{Binding VisibleChannels}"
                                    IsVisible="{Binding ShowStandardChannelList}"
                                    SelectionMode="Single"
                                    SelectionChanged="OnChannelSelectionChanged"
                                    RemainingItemsThreshold="8"
                                    RemainingItemsThresholdReached="OnVisibleChannelsRemainingItemsThresholdReached"
                                    BackgroundColor="Transparent">
                        <CollectionView.EmptyView>
                            <VerticalStackLayout Padding="24"
                                                 Spacing="6"
                                                 HorizontalOptions="Center"
                                                 VerticalOptions="Center">
                                <Label Text="{Binding EmptyStateText}"
                                       HorizontalTextAlignment="Center"
                                       TextColor="#CBD5E1" />
                            </VerticalStackLayout>
                        </CollectionView.EmptyView>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:PlaylistChannel">
                                <Border Margin="0,0,0,8"
                                        Padding="12"
                                        BackgroundColor="#0F172A"
                                        Stroke="#1E293B"
                                        StrokeShape="RoundRectangle 14">
                                    <Grid ColumnDefinitions="52,*,Auto"
                                          ColumnSpacing="12">
                                        <Border WidthRequest="52"
                                                HeightRequest="52"
                                                BackgroundColor="#111827"
                                                Stroke="#334155"
                                                StrokeShape="RoundRectangle 12">
                                            <Grid>
                                                <Label Text="{Binding ArtworkPlaceholderText}"
                                                       FontAttributes="Bold"
                                                       FontSize="16"
                                                       HorizontalTextAlignment="Center"
                                                       VerticalTextAlignment="Center"
                                                       TextColor="#64748B">
                                                    <Label.Triggers>
                                                        <DataTrigger TargetType="Label"
                                                                     Binding="{Binding HasArtwork}"
                                                                     Value="True">
                                                            <Setter Property="IsVisible"
                                                                    Value="False" />
                                                        </DataTrigger>
                                                    </Label.Triggers>
                                                </Label>

                                                <Image Source="{Binding ArtworkPath}"
                                                       Aspect="AspectFit"
                                                       Opacity="0">
                                                    <Image.Triggers>
                                                        <DataTrigger TargetType="Image"
                                                                     Binding="{Binding HasArtwork}"
                                                                     Value="True">
                                                            <Setter Property="Opacity"
                                                                    Value="1" />
                                                        </DataTrigger>
                                                    </Image.Triggers>
                                                </Image>
                                            </Grid>
                                        </Border>

                                        <VerticalStackLayout Grid.Column="1"
                                                             Spacing="2"
                                                             VerticalOptions="Center">
                                            <Label Text="{Binding DisplayName}"
                                                   FontAttributes="Bold"
                                                   FontSize="15"
                                                   TextColor="#E2E8F0"
                                                   LineBreakMode="TailTruncation" />
                                            <Label Text="{Binding CategoryName}"
                                                   FontSize="12"
                                                   TextColor="#94A3B8"
                                                   LineBreakMode="TailTruncation" />
                                            <HorizontalStackLayout BindableLayout.ItemsSource="{Binding CompactMetadataChips}"
                                                                   Spacing="5">
                                                <BindableLayout.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Padding="7,2"
                                                                BackgroundColor="#082F49"
                                                                Stroke="#0E7490"
                                                                StrokeShape="RoundRectangle 999">
                                                            <Label Text="{Binding .}"
                                                                   FontSize="10"
                                                                   FontAttributes="Bold"
                                                                   TextColor="#BAE6FD" />
                                                        </Border>
                                                    </DataTemplate>
                                                </BindableLayout.ItemTemplate>
                                            </HorizontalStackLayout>
                                            <Label Text="{Binding ContentTypeLabel}"
                                                   FontSize="11"
                                                   TextColor="#38BDF8" />
                                        </VerticalStackLayout>

                                        <Button Grid.Column="2"
                                                CommandParameter="{Binding .}"
                                                Clicked="OnFavoriteClicked"
                                                Text="&#x2661;"
                                                FontSize="24"
                                                FontAttributes="Bold"
                                                WidthRequest="44"
                                                HeightRequest="44"
                                                Padding="0"
                                                CornerRadius="22"
                                                BackgroundColor="#111827"
                                                BorderColor="#334155"
                                                BorderWidth="1"
                                                TextColor="#F8FAFC"
                                                VerticalOptions="Center">
                                            <Button.Triggers>
                                                <DataTrigger TargetType="Button"
                                                             Binding="{Binding IsFavorite}"
                                                             Value="True">
                                                    <Setter Property="Text"
                                                            Value="&#x2665;" />
                                                    <Setter Property="TextColor"
                                                            Value="#EF4444" />
                                                    <Setter Property="BorderColor"
                                                            Value="#EF4444" />
                                                    <Setter Property="BackgroundColor"
                                                            Value="#1A0B10" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Button"
                                                             Binding="{Binding IsFavorite}"
                                                             Value="False">
                                                    <Setter Property="Text"
                                                            Value="&#x2661;" />
                                                    <Setter Property="TextColor"
                                                            Value="#F8FAFC" />
                                                    <Setter Property="BorderColor"
                                                            Value="#334155" />
                                                    <Setter Property="BackgroundColor"
                                                            Value="#111827" />
                                                </DataTrigger>
                                            </Button.Triggers>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Grid IsVisible="{Binding ShowMovieDetail}"
                          RowDefinitions="Auto,*"
                          RowSpacing="12">
                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="10">
                            <Button Text="Tillbaka"
                                    Clicked="OnMovieBackClicked"
                                    BackgroundColor="#1E293B"
                                    BorderColor="#334155"
                                    BorderWidth="1"
                                    TextColor="#E2E8F0" />
                        </Grid>

                        <ScrollView Grid.Row="1">
                            <VerticalStackLayout Spacing="14">
                                <Border Padding="14"
                                        BackgroundColor="#0F172A"
                                        Stroke="#1E293B"
                                        StrokeShape="RoundRectangle 16">
                                    <Grid ColumnDefinitions="96,*"
                                          ColumnSpacing="14">
                                        <Border WidthRequest="96"
                                                HeightRequest="140"
                                                BackgroundColor="#111827"
                                                Stroke="#334155"
                                                StrokeShape="RoundRectangle 14">
                                            <Grid>
                                                <Label Text="{Binding SelectedMovieChannel.ArtworkPlaceholderText}"
                                                       FontAttributes="Bold"
                                                       FontSize="26"
                                                       HorizontalTextAlignment="Center"
                                                       VerticalTextAlignment="Center"
                                                       TextColor="#64748B">
                                                    <Label.Triggers>
                                                        <DataTrigger TargetType="Label"
                                                                     Binding="{Binding SelectedMovieChannel.HasArtwork}"
                                                                     Value="True">
                                                            <Setter Property="IsVisible"
                                                                    Value="False" />
                                                        </DataTrigger>
                                                    </Label.Triggers>
                                                </Label>

                                                <Image Source="{Binding SelectedMovieChannel.ArtworkPath}"
                                                       Aspect="AspectFit"
                                                       Opacity="0">
                                                    <Image.Triggers>
                                                        <DataTrigger TargetType="Image"
                                                                     Binding="{Binding SelectedMovieChannel.HasArtwork}"
                                                                     Value="True">
                                                            <Setter Property="Opacity"
                                                                    Value="1" />
                                                        </DataTrigger>
                                                    </Image.Triggers>
                                                </Image>
                                            </Grid>
                                        </Border>

                                        <VerticalStackLayout Grid.Column="1"
                                                             Spacing="8">
                                            <Label Text="{Binding MovieDetailTitle}"
                                                   FontAttributes="Bold"
                                                   FontSize="20"
                                                   TextColor="#F8FAFC"
                                                   LineBreakMode="WordWrap" />
                                            <Label Text="{Binding MovieDetailCategoryText}"
                                                   FontSize="13"
                                                   TextColor="#94A3B8" />
                                            <HorizontalStackLayout BindableLayout.ItemsSource="{Binding SelectedMovieChannel.MetadataChips}"
                                                                   Spacing="6">
                                                <BindableLayout.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Padding="8,3"
                                                                BackgroundColor="#082F49"
                                                                Stroke="#0E7490"
                                                                StrokeShape="RoundRectangle 999">
                                                            <Label Text="{Binding .}"
                                                                   FontSize="11"
                                                                   FontAttributes="Bold"
                                                                   TextColor="#BAE6FD" />
                                                        </Border>
                                                    </DataTemplate>
                                                </BindableLayout.ItemTemplate>
                                            </HorizontalStackLayout>
                                            <Border Padding="10,4"
                                                    HorizontalOptions="Start"
                                                    BackgroundColor="#082F49"
                                                    Stroke="#0E7490"
                                                    StrokeShape="RoundRectangle 999">
                                                <Label Text="{Binding SelectedMovieChannel.ContentTypeLabel}"
                                                       FontSize="11"
                                                       FontAttributes="Bold"
                                                       TextColor="#BAE6FD" />
                                            </Border>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>

                                <Grid ColumnDefinitions="Auto,*"
                                      ColumnSpacing="8"
                                      IsVisible="{Binding IsMovieDetailLoading}">
                                    <ActivityIndicator IsRunning="{Binding IsMovieDetailLoading}"
                                                       WidthRequest="18"
                                                       HeightRequest="18"
                                                       Color="#38BDF8" />
                                    <Label Grid.Column="1"
                                           Text="Hämtar metadata..."
                                           FontSize="12"
                                           TextColor="#94A3B8"
                                           VerticalTextAlignment="Center" />
                                </Grid>

                                <Border Padding="14"
                                        BackgroundColor="#07111F"
                                        Stroke="#1E293B"
                                        StrokeShape="RoundRectangle 14">
                                    <VerticalStackLayout Spacing="12">
                                        <Label Text="{Binding MovieDetailPlotText}"
                                               FontSize="13"
                                               LineBreakMode="WordWrap"
                                               TextColor="#CBD5E1" />

                                        <Grid ColumnDefinitions="*,*"
                                              RowDefinitions="Auto,Auto,Auto"
                                              ColumnSpacing="10"
                                              RowSpacing="10">
                                            <VerticalStackLayout Spacing="2">
                                                <Label Text="Genre"
                                                       FontSize="10"
                                                       TextColor="#64748B" />
                                                <Label Text="{Binding MovieDetailGenreText}"
                                                       FontSize="13"
                                                       TextColor="#E2E8F0"
                                                       LineBreakMode="TailTruncation" />
                                            </VerticalStackLayout>

                                            <VerticalStackLayout Grid.Column="1"
                                                                 Spacing="2">
                                                <Label Text="Längd"
                                                       FontSize="10"
                                                       TextColor="#64748B" />
                                                <Label Text="{Binding MovieDetailDurationText}"
                                                       FontSize="13"
                                                       TextColor="#E2E8F0"
                                                       LineBreakMode="TailTruncation" />
                                            </VerticalStackLayout>

                                            <VerticalStackLayout Grid.Row="1"
                                                                 Spacing="2">
                                                <Label Text="Betyg"
                                                       FontSize="10"
                                                       TextColor="#64748B" />
                                                <Label Text="{Binding MovieDetailRatingText}"
                                                       FontSize="13"
                                                       TextColor="#E2E8F0"
                                                       LineBreakMode="TailTruncation" />
                                            </VerticalStackLayout>

                                            <VerticalStackLayout Grid.Row="1"
                                                                 Grid.Column="1"
                                                                 Spacing="2">
                                                <Label Text="Premiär"
                                                       FontSize="10"
                                                       TextColor="#64748B" />
                                                <Label Text="{Binding MovieDetailReleaseDateText}"
                                                       FontSize="13"
                                                       TextColor="#E2E8F0"
                                                       LineBreakMode="TailTruncation" />
                                            </VerticalStackLayout>

                                            <VerticalStackLayout Grid.Row="2"
                                                                 Spacing="2">
                                                <Label Text="Regi"
                                                       FontSize="10"
                                                       TextColor="#64748B" />
                                                <Label Text="{Binding MovieDetailDirectorText}"
                                                       FontSize="13"
                                                       TextColor="#E2E8F0"
                                                       LineBreakMode="TailTruncation" />
                                            </VerticalStackLayout>

                                            <VerticalStackLayout Grid.Row="2"
                                                                 Grid.Column="1"
                                                                 Spacing="2">
                                                <Label Text="Cast"
                                                       FontSize="10"
                                                       TextColor="#64748B" />
                                                <Label Text="{Binding MovieDetailCastText}"
                                                       FontSize="13"
                                                       TextColor="#E2E8F0"
                                                       MaxLines="2"
                                                       LineBreakMode="TailTruncation" />
                                            </VerticalStackLayout>
                                        </Grid>
                                    </VerticalStackLayout>
                                </Border>

                                <HorizontalStackLayout Spacing="10">
                                    <Button Text="Starta film"
                                            Clicked="OnMoviePlayClicked"
                                            BackgroundColor="#0E7490"
                                            BorderColor="#38BDF8"
                                            BorderWidth="1"
                                            TextColor="White"
                                            FontAttributes="Bold"
                                            Padding="18,12" />

                                    <Button CommandParameter="{Binding SelectedMovieChannel}"
                                            Clicked="OnFavoriteClicked"
                                            Text="&#x2661;"
                                            FontSize="24"
                                            FontAttributes="Bold"
                                            WidthRequest="48"
                                            HeightRequest="48"
                                            Padding="0"
                                            CornerRadius="24"
                                            BackgroundColor="#111827"
                                            BorderColor="#334155"
                                            BorderWidth="1"
                                            TextColor="#F8FAFC">
                                        <Button.Triggers>
                                            <DataTrigger TargetType="Button"
                                                         Binding="{Binding SelectedMovieChannel.IsFavorite}"
                                                         Value="True">
                                                <Setter Property="Text"
                                                        Value="&#x2665;" />
                                                <Setter Property="TextColor"
                                                        Value="#EF4444" />
                                                <Setter Property="BorderColor"
                                                        Value="#EF4444" />
                                                <Setter Property="BackgroundColor"
                                                        Value="#1A0B10" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Button"
                                                         Binding="{Binding SelectedMovieChannel.IsFavorite}"
                                                         Value="False">
                                                <Setter Property="Text"
                                                        Value="&#x2661;" />
                                                <Setter Property="TextColor"
                                                        Value="#F8FAFC" />
                                                <Setter Property="BorderColor"
                                                        Value="#334155" />
                                                <Setter Property="BackgroundColor"
                                                        Value="#111827" />
                                            </DataTrigger>
                                        </Button.Triggers>
                                    </Button>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </ScrollView>
                    </Grid>

                    <CollectionView ItemsSource="{Binding VisibleSeriesGroups}"
                                    IsVisible="{Binding ShowSeriesOverview}"
                                    SelectionMode="Single"
                                    SelectionChanged="OnSeriesGroupSelectionChanged"
                                    RemainingItemsThreshold="6"
                                    RemainingItemsThresholdReached="OnVisibleSeriesGroupsRemainingItemsThresholdReached"
                                    BackgroundColor="Transparent">
                        <CollectionView.EmptyView>
                            <VerticalStackLayout Padding="24"
                                                 Spacing="6"
                                                 HorizontalOptions="Center"
                                                 VerticalOptions="Center">
                                <Label Text="{Binding EmptyStateText}"
                                       HorizontalTextAlignment="Center"
                                       TextColor="#CBD5E1" />
                            </VerticalStackLayout>
                        </CollectionView.EmptyView>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:SeriesGroupItem">
                                <Border Margin="0,0,0,8"
                                        Padding="12"
                                        BackgroundColor="#0F172A"
                                        Stroke="#1E293B"
                                        StrokeShape="RoundRectangle 14">
                                    <Grid ColumnDefinitions="52,*,Auto"
                                          ColumnSpacing="12">
                                        <Border WidthRequest="52"
                                                HeightRequest="52"
                                                BackgroundColor="#111827"
                                                Stroke="#334155"
                                                StrokeShape="RoundRectangle 12">
                                            <Grid>
                                                <Label Text="{Binding RepresentativeChannel.ArtworkPlaceholderText}"
                                                       FontAttributes="Bold"
                                                       FontSize="16"
                                                       HorizontalTextAlignment="Center"
                                                       VerticalTextAlignment="Center"
                                                       TextColor="#64748B">
                                                    <Label.Triggers>
                                                        <DataTrigger TargetType="Label"
                                                                     Binding="{Binding RepresentativeChannel.HasArtwork}"
                                                                     Value="True">
                                                            <Setter Property="IsVisible"
                                                                    Value="False" />
                                                        </DataTrigger>
                                                    </Label.Triggers>
                                                </Label>

                                                <Image Source="{Binding RepresentativeChannel.ArtworkPath}"
                                                       Aspect="AspectFit"
                                                       Opacity="0">
                                                    <Image.Triggers>
                                                        <DataTrigger TargetType="Image"
                                                                     Binding="{Binding RepresentativeChannel.HasArtwork}"
                                                                     Value="True">
                                                            <Setter Property="Opacity"
                                                                    Value="1" />
                                                        </DataTrigger>
                                                    </Image.Triggers>
                                                </Image>
                                            </Grid>
                                        </Border>

                                        <VerticalStackLayout Grid.Column="1"
                                                             Spacing="2"
                                                             VerticalOptions="Center">
                                            <Label Text="{Binding Title}"
                                                   FontAttributes="Bold"
                                                   FontSize="15"
                                                   TextColor="#E2E8F0"
                                                   LineBreakMode="TailTruncation" />
                                            <Label Text="{Binding CategoryName}"
                                                   FontSize="12"
                                                   TextColor="#94A3B8"
                                                   LineBreakMode="TailTruncation" />
                                            <Label Text="{Binding SummaryText}"
                                                   FontSize="11"
                                                   TextColor="#38BDF8" />
                                        </VerticalStackLayout>

                                        <Border Grid.Column="2"
                                                Padding="10,6"
                                                BackgroundColor="#1E293B"
                                                Stroke="#334155"
                                                StrokeShape="RoundRectangle 999"
                                                VerticalOptions="Center">
                                            <Label Text="Öppna"
                                                   FontSize="11"
                                                   FontAttributes="Bold"
                                                   TextColor="#E2E8F0" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Grid IsVisible="{Binding ShowSeriesDetail}"
                          RowDefinitions="Auto,Auto,*"
                          RowSpacing="10">
                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="10">
                            <Button Text="Tillbaka"
                                    Clicked="OnSeriesBackClicked"
                                    BackgroundColor="#1E293B"
                                    BorderColor="#334155"
                                    BorderWidth="1"
                                    TextColor="#E2E8F0" />

                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="2">
                                <Label Text="{Binding SeriesDetailTitle}"
                                       FontAttributes="Bold"
                                       FontSize="18"
                                       TextColor="#E2E8F0" />
                                <Label Text="{Binding SeriesDetailSubtitle}"
                                       FontSize="12"
                                       TextColor="#94A3B8" />
                            </VerticalStackLayout>
                        </Grid>

                        <ScrollView Grid.Row="1"
                                    Orientation="Horizontal"
                                    HorizontalScrollBarVisibility="Never">
                            <HorizontalStackLayout BindableLayout.ItemsSource="{Binding VisibleSeriesSeasons}"
                                                   Spacing="8">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:SeriesSeasonItem">
                                        <Button Text="{Binding Label}"
                                                CommandParameter="{Binding .}"
                                                Clicked="OnSeriesSeasonClicked"
                                                BackgroundColor="#0F172A"
                                                BorderColor="#334155"
                                                BorderWidth="1"
                                                TextColor="#CBD5E1"
                                                Padding="14,8">
                                            <Button.Triggers>
                                                <DataTrigger TargetType="Button"
                                                             Binding="{Binding IsSelected}"
                                                             Value="True">
                                                    <Setter Property="BackgroundColor"
                                                            Value="#0E7490" />
                                                    <Setter Property="BorderColor"
                                                            Value="#38BDF8" />
                                                    <Setter Property="TextColor"
                                                            Value="White" />
                                                </DataTrigger>
                                            </Button.Triggers>
                                        </Button>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </HorizontalStackLayout>
                        </ScrollView>

                        <CollectionView Grid.Row="2"
                                        ItemsSource="{Binding CurrentSeriesEpisodes}"
                                        SelectionMode="Single"
                                        SelectionChanged="OnSeriesEpisodeSelectionChanged"
                                        BackgroundColor="Transparent">
                            <CollectionView.EmptyView>
                                <VerticalStackLayout Padding="24"
                                                     Spacing="6"
                                                     HorizontalOptions="Center"
                                                     VerticalOptions="Center">
                                    <Label Text="{Binding EmptyStateText}"
                                           HorizontalTextAlignment="Center"
                                           TextColor="#CBD5E1" />
                                </VerticalStackLayout>
                            </CollectionView.EmptyView>

                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:SeriesEpisodeItem">
                                    <Border Margin="0,0,0,8"
                                            Padding="12"
                                            BackgroundColor="#0F172A"
                                            Stroke="#1E293B"
                                            StrokeShape="RoundRectangle 14">
                                        <Grid ColumnDefinitions="*,Auto"
                                              ColumnSpacing="12">
                                            <VerticalStackLayout Spacing="2"
                                                                 VerticalOptions="Center">
                                                <Label Text="{Binding Title}"
                                                       FontAttributes="Bold"
                                                       FontSize="15"
                                                       TextColor="#E2E8F0"
                                                       LineBreakMode="TailTruncation" />
                                                <Label Text="{Binding Subtitle}"
                                                       FontSize="12"
                                                       TextColor="#94A3B8" />
                                            </VerticalStackLayout>

                                            <Button Grid.Column="1"
                                                    CommandParameter="{Binding Channel}"
                                                    Clicked="OnFavoriteClicked"
                                                    Text="&#x2661;"
                                                    FontSize="24"
                                                    FontAttributes="Bold"
                                                    WidthRequest="44"
                                                    HeightRequest="44"
                                                    Padding="0"
                                                    CornerRadius="22"
                                                    BackgroundColor="#111827"
                                                    BorderColor="#334155"
                                                    BorderWidth="1"
                                                    TextColor="#F8FAFC"
                                                    VerticalOptions="Center">
                                                <Button.Triggers>
                                                    <DataTrigger TargetType="Button"
                                                                 Binding="{Binding Channel.IsFavorite}"
                                                                 Value="True">
                                                        <Setter Property="Text"
                                                                Value="&#x2665;" />
                                                        <Setter Property="TextColor"
                                                                Value="#EF4444" />
                                                        <Setter Property="BorderColor"
                                                                Value="#EF4444" />
                                                        <Setter Property="BackgroundColor"
                                                                Value="#1A0B10" />
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Button"
                                                                 Binding="{Binding Channel.IsFavorite}"
                                                                 Value="False">
                                                        <Setter Property="Text"
                                                                Value="&#x2661;" />
                                                        <Setter Property="TextColor"
                                                                Value="#F8FAFC" />
                                                        <Setter Property="BorderColor"
                                                                Value="#334155" />
                                                        <Setter Property="BackgroundColor"
                                                                Value="#111827" />
                                                    </DataTrigger>
                                                </Button.Triggers>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Grid>

                </Grid>

                <Grid Grid.RowSpan="6"
                      IsVisible="{Binding ShowContentLoadingOverlay}"
                      BackgroundColor="#CC020617"
                      InputTransparent="False">
                    <Border Padding="22"
                            BackgroundColor="#091223"
                            Stroke="#1E293B"
                            StrokeShape="RoundRectangle 18"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            MaximumWidthRequest="300">
                        <VerticalStackLayout Spacing="12">
                            <ActivityIndicator IsVisible="{Binding ShowContentLoadingOverlay}"
                                               IsRunning="{Binding ShowContentLoadingOverlay}"
                                               Color="#38BDF8"
                                               HeightRequest="42" />
                            <Label Text="{Binding StatusText}"
                                   HorizontalTextAlignment="Center"
                                   TextColor="#E2E8F0" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <Grid Grid.RowSpan="2"
              IsVisible="{Binding ShowEmbeddedPlayer}"
              BackgroundColor="#F2020617"
              InputTransparent="False">
            <Grid Padding="16"
                  RowDefinitions="Auto,*"
                  RowSpacing="12">
                <Border Grid.Row="0"
                        Padding="14,12"
                        BackgroundColor="#091223"
                        Stroke="#182A45"
                        StrokeShape="RoundRectangle 18">
                    <Grid ColumnDefinitions="*,Auto,Auto"
                          ColumnSpacing="12">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="{Binding EmbeddedPlayerTitle}"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#F8FAFC"
                                   LineBreakMode="TailTruncation" />
                            <Label Text="{Binding EmbeddedPlayerSubtitle}"
                                   FontSize="12"
                                   TextColor="#8EA3BF"
                                   LineBreakMode="TailTruncation" />
                        </VerticalStackLayout>

                        <Button Grid.Column="1"
                                Text="Undertexter"
                                Clicked="OnOpenEmbeddedSubtitleOptionsClicked"
                                IsEnabled="{Binding CanSelectEmbeddedSubtitles}"
                                BackgroundColor="#0F172A"
                                BorderColor="#334155"
                                BorderWidth="1"
                                TextColor="#E2E8F0" />

                        <Button Grid.Column="2"
                                Text="Stäng"
                                Clicked="OnCloseEmbeddedPlayerClicked"
                                BackgroundColor="#0F172A"
                                BorderColor="#334155"
                                BorderWidth="1"
                                TextColor="#E2E8F0" />
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        BackgroundColor="Black"
                        Stroke="#182A45"
                        StrokeShape="RoundRectangle 22">
                    <Grid>
                        <toolkit:MediaElement x:Name="EmbeddedMediaElement"
                                              Aspect="AspectFit"
                                              ShouldAutoPlay="True"
                                              ShouldShowPlaybackControls="True"
                                              MediaOpened="OnEmbeddedMediaOpened"
                                              MediaEnded="OnEmbeddedMediaEnded"
                                              MediaFailed="OnEmbeddedMediaFailed" />

                        <Grid IsVisible="{Binding IsEmbeddedPlayerLoading}"
                              BackgroundColor="#B3000000"
                              InputTransparent="False">
                            <VerticalStackLayout Spacing="12"
                                                 HorizontalOptions="Center"
                                                 VerticalOptions="Center">
                                <ActivityIndicator IsVisible="{Binding IsEmbeddedPlayerLoading}"
                                                   IsRunning="{Binding IsEmbeddedPlayerLoading}"
                                                   Color="#38BDF8"
                                                   HeightRequest="42" />
                                <Label Text="{Binding EmbeddedPlayerStatusText}"
                                       HorizontalTextAlignment="Center"
                                       TextColor="#E2E8F0" />
                            </VerticalStackLayout>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
