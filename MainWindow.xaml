                                <Button Background="#38BDF8"
                                        BorderBrush="#38BDF8"
                                        Click="LoadPlaylist_Click"
                                        Content="{Binding LoadButtonText}"
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        Foreground="#020617"
                                        IsDefault="True"
                                        Style="{StaticResource DashboardPillButtonStyle}" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <Grid Background="#CC06111C"
                  Panel.ZIndex="10"
                  Visibility="{Binding CategoryManagerVisibility}">
                <Border Margin="24"
                        Background="#091221"
                        BorderBrush="#1E2D47"
                        BorderThickness="1"
                        CornerRadius="28">
                    <Grid Margin="28">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel LastChildFill="False">
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Foreground="#F8FAFC"
                                           FontSize="26"
                                           FontWeight="SemiBold"
                                           Text="Sortera och dölj kategorier" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="#94A3B8"
                                           FontSize="13"
                                           Text="{Binding PlaylistCategoryManagerHintText}"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <StackPanel DockPanel.Dock="Right"
                                        Orientation="Horizontal">
                                <Button Margin="0,0,10,0"
                                        Click="MarkAllCategories_Click"
                                        Content="Markera alla"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Style="{StaticResource DashboardSecondaryButtonStyle}" />
                                <Button Margin="0,0,10,0"
                                        Click="ClearAllCategories_Click"
                                        Content="Avmarkera alla"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Style="{StaticResource DashboardSecondaryButtonStyle}" />
                                <Button Margin="0,0,10,0"
                                        Click="ResetCategoryPreferences_Click"
                                        Content="Återställ"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Style="{StaticResource DashboardSecondaryButtonStyle}" />
                                <Button Click="CloseCategoryManager_Click"
                                        Content="Stäng"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Style="{StaticResource DashboardSecondaryButtonStyle}" />
                            </StackPanel>
                        </DockPanel>

                        <ListBox Grid.Row="1"
                                 Margin="0,22,0,0"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ItemContainerStyle="{StaticResource SectionSelectorItemStyle}"
                                 ItemsSource="{Binding BrowseSections}"
                                 SelectedItem="{Binding SelectedCategoryManagerSectionOption, Mode=TwoWay}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Disabled">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:BrowseSectionOption}">
                                    <TextBlock Foreground="White"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Text="{Binding Label}" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Border Grid.Row="2"
                                Margin="0,22,0,0"
                                Padding="16"
                                Background="#07101D"
                                BorderBrush="#1E2D47"
                                BorderThickness="1"
                                CornerRadius="18">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding PlaylistCategoryItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:PlaylistCategoryItem}">
                                            <Border Margin="0,0,0,10"
                                                    Padding="14"
                                                    Background="#05080E"
                                                    BorderBrush="#162235"
                                                    BorderThickness="1"
                                                    CornerRadius="12">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <CheckBox Margin="0,0,14,0"
                                                              VerticalAlignment="Center"
                                                              Click="CategoryVisibilityCheckBox_Click"
                                                              IsChecked="{Binding IsVisible, Mode=TwoWay}" />

                                                    <StackPanel Grid.Column="1"
                                                                VerticalAlignment="Center">
                                                        <TextBlock Foreground="White"
                                                                   FontSize="14"
                                                                   FontWeight="SemiBold"
                                                                   Text="{Binding Label}" />
                                                        <TextBlock Margin="0,4,0,0"
                                                                   Foreground="#64748B"
                                                                   FontSize="11"
                                                                   Text="Syns i browser-vyn nar den Är ikryssad." />
                                                    </StackPanel>

                                                    <Border Grid.Column="2"
                                                            Margin="14,0,14,0"
                                                            Padding="12,6"
                                                            VerticalAlignment="Center"
                                                            Background="#0F172A"
                                                            BorderBrush="#1E293B"
                                                            BorderThickness="1"
                                                            CornerRadius="999">
                                                        <TextBlock Foreground="#38BDF8"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   Text="{Binding Count}" />
                                                    </Border>

                                                    <Button Grid.Column="3"
                                                            Margin="0,0,10,0"
                                                            Padding="14,9"
                                                            Click="MoveCategoryUp_Click"
                                                            Content="Upp"
                                                            FontSize="11"
                                                            FontWeight="SemiBold"
                                                            Style="{StaticResource DashboardSecondaryButtonStyle}" />

                                                    <Button Grid.Column="4"
                                                            Padding="14,9"
                                                            Click="MoveCategoryDown_Click"
                                                            Content="Ner"
                                                            FontSize="11"
                                                            FontWeight="SemiBold"
                                                            Style="{StaticResource DashboardSecondaryButtonStyle}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Grid x:Name="FullscreenHost"
              Grid.RowSpan="4"
              Margin="-18"
              Panel.ZIndex="50"
              SizeChanged="FullscreenHost_SizeChanged"
              Background="Black"
              Visibility="{Binding ShowFullscreenPlayer, Converter={StaticResource BooleanToVisibilityConverter}}">
            <vlc:VideoView x:Name="VideoView"
                           FocusVisualStyle="{x:Null}"
                           Focusable="False" />

            <Grid Background="Transparent"
                  MouseMove="FullscreenOverlay_MouseMove" />

            <Border Margin="24"
                    Padding="16,12"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Top"
                    Background="#99050B13"
                    MouseMove="FullscreenOverlay_MouseMove"
                    CornerRadius="16">
                <Border.Visibility>
                    <Binding Path="ShowFullscreenChrome" Converter="{StaticResource BooleanToVisibilityConverter}" />
                </Border.Visibility>
                <DockPanel LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Foreground="#64748B"
                                   FontSize="11"
                                   Text="Fullscreen playback" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="#F8FAFC"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Text="{Binding SelectedChannel.Name}" />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="#CBD5E1"
                                   FontSize="12"
                                   Text="{Binding SelectedChannel.FullscreenSubtitleText}"
                                   TextWrapping="Wrap" />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="#94A3B8"
                                   FontSize="12"
                                   Text="{Binding SelectedChannel.FullscreenGuideText}"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding SelectedChannel.HasNextProgramme, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>

                    <TextBlock DockPanel.Dock="Right"
                               VerticalAlignment="Center"
                               Foreground="#CBD5E1"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Text="Escape för att stänga" />
                </DockPanel>
            </Border>

        </Grid>

        <Popup AllowsTransparency="True"
               DataContext="{Binding ElementName=FullscreenHost, Path=DataContext}"
               Placement="Absolute"
               HorizontalOffset="{Binding FullscreenControlsPopupLeft}"
               VerticalOffset="{Binding FullscreenControlsPopupTop}"
               IsOpen="{Binding ShowFullscreenChromePopup, Mode=OneWay}"
               PopupAnimation="Fade"
               StaysOpen="True">
            <Border Width="{Binding FullscreenChromeWidth}"
                    Padding="18"
                    Background="#CC020617"
                    CornerRadius="18"
                    SizeChanged="FullscreenControlsChrome_SizeChanged">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Foreground="#CBD5E1"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Text="{Binding CurrentTimeText}" />

                        <TextBlock Grid.Column="1"
                                   HorizontalAlignment="Center"
                                   Foreground="#64748B"
                                   FontSize="11"
                                   Text="{Binding PlaybackModeText}" />

                        <TextBlock Grid.Column="2"
                                   Foreground="#CBD5E1"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Text="{Binding DurationText}" />
                    </Grid>

                    <Slider x:Name="SeekSlider"
                            Margin="0,12,0,0"
                            Minimum="0"
                            Maximum="{Binding PlaybackDurationMilliseconds}"
                            Value="{Binding PlaybackPositionMilliseconds}"
                            IsEnabled="{Binding CanSeek}"
                            PreviewMouseLeftButtonDown="SeekSlider_PreviewMouseLeftButtonDown"
                            PreviewMouseLeftButtonUp="SeekSlider_PreviewMouseLeftButtonUp" />

                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="150" />
                        </Grid.ColumnDefinitions>

                        <Button Padding="14,9"
                                Margin="0,0,10,0"
                                Background="#38BDF8"
                                BorderThickness="0"
                                Click="PlayPauseButton_Click"
                                Content="{Binding PlayPauseButtonText}"
                                Foreground="#020617"
                                FontSize="12"
                                FontWeight="SemiBold"
                                IsEnabled="{Binding CanControlPlayback}" />

                        <Button Grid.Column="1"
                                Padding="14,9"
                                Margin="0,0,10,0"
                                Background="#111827"
                                BorderBrush="#334155"
                                BorderThickness="1"
                                Click="StopButton_Click"
                                Content="Stop"
                                Foreground="#E2E8F0"
                                FontSize="12"
                                FontWeight="SemiBold"
                                IsEnabled="{Binding CanControlPlayback}" />

                        <Button Grid.Column="2"
                                Padding="14,9"
                                Margin="0,0,10,0"
                                Background="#111827"
                                BorderBrush="#334155"
                                BorderThickness="1"
                                Click="MuteButton_Click"
                                Content="{Binding MuteButtonText}"
                                Foreground="#E2E8F0"
                                FontSize="12"
                                FontWeight="SemiBold"
                                IsEnabled="{Binding CanControlPlayback}" />

                        <Button Grid.Column="3"
                                Padding="14,9"
                                Margin="0,0,10,0"
                                Background="#111827"
                                BorderBrush="#334155"
                                BorderThickness="1"
                                Click="FullscreenButton_Click"
                                Content="{Binding FullscreenButtonText}"
                                Foreground="#E2E8F0"
                                FontSize="12"
                                FontWeight="SemiBold" />

                        <StackPanel Grid.Column="5"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock Margin="0,0,10,0"
                                       VerticalAlignment="Center"
                                       Foreground="#94A3B8"
                                       FontSize="12"
                                       Text="Volym" />
                            <Slider Width="96"
                                    Minimum="0"
                                    Maximum="100"
                                    Value="{Binding Volume}"
                                    ValueChanged="VolumeSlider_ValueChanged"
                                    IsEnabled="{Binding CanControlPlayback}" />
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,14,0,0"
                          Visibility="{Binding ShowPlaybackTrackSelectors, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Visibility="{Binding ShowAudioTrackSelector, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Foreground="#94A3B8"
                                       FontSize="11"
                                       Text="LjudspÅr" />
                            <ComboBox Margin="0,8,0,0"
                                      Style="{StaticResource FullscreenTrackComboBoxStyle}"
                                      ItemsSource="{Binding AudioTrackOptions}"
                                      SelectedItem="{Binding SelectedAudioTrackOption, Mode=OneWay}"
                                      DisplayMemberPath="Label"
                                      SelectionChanged="AudioTrackComboBox_SelectionChanged"
                                      IsEnabled="{Binding CanSelectAudioTrack}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2"
                                    Visibility="{Binding ShowSubtitleTrackSelector, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Foreground="#94A3B8"
                                       FontSize="11"
                                       Text="Undertext" />
                            <ComboBox Margin="0,8,0,0"
                                      Style="{StaticResource FullscreenTrackComboBoxStyle}"
                                      ItemsSource="{Binding SubtitleTrackOptions}"
                                      SelectedItem="{Binding SelectedSubtitleTrackOption, Mode=OneWay}"
                                      DisplayMemberPath="Label"
                                      SelectionChanged="SubtitleTrackComboBox_SelectionChanged"
                                      IsEnabled="{Binding CanSelectSubtitleTrack}" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Margin="0,10,0,0"
                               Foreground="#64748B"
                               FontSize="11"
                               Text="{Binding PlayerControlHint}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>
