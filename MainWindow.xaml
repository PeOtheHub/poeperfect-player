<Window x:Class="APTV.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:APTV.Models"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        mc:Ignorable="d"
        Title="PoePerfect Player"
        Width="1360"
        Height="860"
        MinWidth="1180"
        MinHeight="740"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="SpinnerRotateStyle" TargetType="FrameworkElement">
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <RotateTransform />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsVisible" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard x:Name="SpinnerStoryboard">
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                 From="0"
                                                 To="360"
                                                 Duration="0:0:0.9" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <StopStoryboard BeginStoryboardName="SpinnerStoryboard" />
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MinimalScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="Background" Value="#6B9FB3C8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="999" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#A438BDF8" />
                </Trigger>
                <Trigger Property="IsDragging" Value="True">
                    <Setter Property="Background" Value="#FF38BDF8" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MinimalScrollBarPageButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Rectangle Fill="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="VerticalMinimalScrollBarTemplate" TargetType="ScrollBar">
            <Grid Width="{TemplateBinding Width}"
                  Background="Transparent">
                <Track x:Name="PART_Track"
                       IsDirectionReversed="True">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.PageUpCommand"
                                      Style="{StaticResource MinimalScrollBarPageButtonStyle}" />
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb MinHeight="36"
                               Style="{StaticResource MinimalScrollBarThumbStyle}" />
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.PageDownCommand"
                                      Style="{StaticResource MinimalScrollBarPageButtonStyle}" />
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>

        <ControlTemplate x:Key="HorizontalMinimalScrollBarTemplate" TargetType="ScrollBar">
            <Grid Height="{TemplateBinding Height}"
                  Background="Transparent">
                <Track x:Name="PART_Track">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.PageLeftCommand"
                                      Style="{StaticResource MinimalScrollBarPageButtonStyle}" />
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb MinWidth="36"
                               Style="{StaticResource MinimalScrollBarThumbStyle}" />
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.PageRightCommand"
                                      Style="{StaticResource MinimalScrollBarPageButtonStyle}" />
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template" Value="{StaticResource VerticalMinimalScrollBarTemplate}" />
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="8" />
                    <Setter Property="Width" Value="Auto" />
                    <Setter Property="Margin" Value="0,6,0,0" />
                    <Setter Property="Template" Value="{StaticResource HorizontalMinimalScrollBarTemplate}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Background" Value="#111827" />
            <Setter Property="BorderBrush" Value="#334155" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#E2E8F0" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#38BDF8" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FullscreenTrackComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Foreground" Value="#E2E8F0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#13263E" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#1D4ED8" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#0E7490" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#38BDF8" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FullscreenTrackComboBoxStyle" TargetType="ComboBox">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Foreground" Value="#E2E8F0" />
            <Setter Property="Background" Value="#0F172A" />
            <Setter Property="BorderBrush" Value="#334155" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource FullscreenTrackComboBoxItemStyle}" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="ComboBorder"
                                                Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                TextElement.Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                CornerRadius="10"
                                                SnapsToDevicePixels="True">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="26" />
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Margin="{Binding Padding, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  TextElement.Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Left"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentStringFormat="{Binding SelectionBoxItemStringFormat, RelativeSource={RelativeSource AncestorType=ComboBox}}" />
                                                <Path Grid.Column="1"
                                                      Margin="0,0,10,0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Center"
                                                      Fill="#94A3B8"
                                                      Data="M 0 0 L 4 4 L 8 0 Z" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#38BDF8" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#38BDF8" />
                                                <Setter TargetName="ComboBorder" Property="Background" Value="#13263E" />
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="ComboBorder" Property="Opacity" Value="0.45" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PopupAnimation="Fade">
                                <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="320"
                                        Margin="0,6,0,0"
                                        Padding="6"
                                        Background="#08111F"
                                        BorderBrush="#1E293B"
                                        BorderThickness="1"
                                        CornerRadius="14">
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ScrollViewer"
                                          Background="Transparent"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
                                          VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}"
                                          CanContentScroll="{TemplateBinding ScrollViewer.CanContentScroll}">
                                <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>

        <Style x:Key="SectionSelectorItemStyle" TargetType="ListBoxItem">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Border"
                                Padding="18,12"
                                Background="#05080E"
                                BorderBrush="#1F2937"
                                BorderThickness="1"
                                CornerRadius="14">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#0E7490" />
                                <Setter TargetName="Border" Property="BorderBrush" Value="#22D3EE" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#334155" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CategoryChipItemStyle" TargetType="ListBoxItem">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Border"
                                Padding="10,8"
                                Background="#020617"
                                BorderBrush="#334155"
                                BorderThickness="1"
                                CornerRadius="10">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1D4ED8" />
                                <Setter TargetName="Border" Property="BorderBrush" Value="#60A5FA" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#60A5FA" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DashboardTileButtonStyle" TargetType="Button">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="24"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Opacity" Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DashboardPillButtonStyle" TargetType="Button">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Background" Value="#0F172A" />
            <Setter Property="BorderBrush" Value="#334155" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#E2E8F0" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#38BDF8" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Opacity" Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DashboardSecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource DashboardPillButtonStyle}">
            <Setter Property="Background" Value="#111827" />
            <Setter Property="BorderBrush" Value="#1F2937" />
            <Setter Property="Foreground" Value="#CBD5E1" />
            <Setter Property="Padding" Value="16,10" />
        </Style>

        <Style x:Key="SidebarCategoryListItemStyle" TargetType="ListBoxItem">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Border"
                                Padding="12,11"
                                Background="#05080E"
                                BorderBrush="#0F172A"
                                BorderThickness="1"
                                CornerRadius="8">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#0E7490" />
                                <Setter TargetName="Border" Property="BorderBrush" Value="#22D3EE" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#1E293B" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PosterTileListItemStyle" TargetType="ListBoxItem">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Margin" Value="0,0,12,14" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Border"
                                Background="Transparent"
                                BorderBrush="#0F172A"
                                BorderThickness="1"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#22D3EE" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Opacity" Value="0.95" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LiveChannelListItemStyle" TargetType="ListBoxItem">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Border"
                                Background="#05080E"
                                BorderBrush="#121A27"
                                BorderThickness="1"
                                CornerRadius="12"
                                SnapsToDevicePixels="True">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#0B1320" />
                                <Setter TargetName="Border" Property="BorderBrush" Value="#22D3EE" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#1E293B" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="18,10"
                Background="#05080D"
                BorderBrush="#121A27"
                BorderThickness="1"
                CornerRadius="18"
                Visibility="{Binding ShowBrowserShell, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Border Padding="12,7"
                                Background="#04070C"
                                BorderBrush="#1E293B"
                                BorderThickness="1"
                                CornerRadius="12">
                            <TextBlock Foreground="#F8FAFC"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Text="PoePerfect Player" />
                        </Border>

                        <Button Margin="14,0,0,0"
                                Padding="16,10"
                                Background="#05080D"
                                BorderBrush="#1E293B"
                                BorderThickness="1"
                                Click="BackToDashboard_Click"
                                Cursor="Hand"
                                Foreground="#E2E8F0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Margin="0,0,8,0"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Text="&#x2190;" />
                                <TextBlock FontSize="12"
                                           FontWeight="SemiBold"
                                           Text="Tillbaka" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock HorizontalAlignment="Center"
                                   Foreground="#F8FAFC"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Text="{Binding BrowseHeaderTitle}" />
                        <TextBlock Margin="0,4,0,0"
                                   HorizontalAlignment="Center"
                                   Foreground="#64748B"
                                   FontSize="11"
                                   Text="{Binding SelectedBrowseSectionOption.Label, TargetNullValue=Innehåll}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button Width="42"
                                Height="42"
                                Margin="0,0,12,0"
                                Background="#04070C"
                                BorderBrush="#1E293B"
                                BorderThickness="1"
                                Click="ToggleSearchPanel_Click"
                                Cursor="Hand"
                                Foreground="#E2E8F0"
                                IsEnabled="{Binding CanSearchCurrentSection}">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       FontSize="16"
                                       Text="&#xE721;" />
                        </Button>

                        <Border Padding="12,7"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Background="#04070C"
                                BorderBrush="#1E293B"
                                BorderThickness="1"
                                CornerRadius="12">
                            <TextBlock Foreground="#22C3FF"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Text="{Binding ChannelCountText}" />
                        </Border>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1"
                        Margin="0,14,0,0"
                        Padding="14"
                        Background="#04070C"
                        BorderBrush="#1E293B"
                        BorderThickness="1"
                        CornerRadius="14"
                        Visibility="{Binding SearchPanelVisibility}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,16,0">
                            <TextBlock Foreground="#CBD5E1"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Text="{Binding SearchPanelTitle}" />
                            <TextBox x:Name="BrowseSearchTextBox"
                                     Margin="0,8,0,0"
                                     Padding="10,8"
                                     Background="#05080D"
                                     BorderBrush="#1E293B"
                                     BorderThickness="1"
                                     Foreground="White"
                                     KeyDown="BrowseSearchTextBox_KeyDown"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <Button Grid.Column="1"
                                Margin="0,24,10,0"
                                Padding="18,10"
                                Click="ExecuteSearch_Click"
                                Content="Sök"
                                IsEnabled="{Binding CanSearchCurrentSection}" />

                        <Button Grid.Column="2"
                                Margin="0,24,10,0"
                                Padding="18,10"
                                Click="ClearSearch_Click"
                                Content="Rensa" />

                        <Button Grid.Column="3"
                                Margin="0,24,0,0"
                                Padding="18,10"
                                Click="CloseSearchPanel_Click"
                                Content="Stäng" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="2"
              Visibility="{Binding ShowBrowserShell, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="0,0,16,0"
                    Background="#05080D"
                    BorderBrush="#121A27"
                    BorderThickness="1"
                    CornerRadius="18">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Margin="2,2,2,12">
                        <TextBlock Foreground="#E5E7EB"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Text="{Binding CategorySectionTitle}" />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="#64748B"
                                   FontSize="11"
                                   Text="{Binding CategorySectionSubtitle}" />
                    </StackPanel>

                    <ListBox Grid.Row="1"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="White"
                             IsEnabled="{Binding CanPickPlaylistFile}"
                             ItemContainerStyle="{StaticResource SidebarCategoryListItemStyle}"
                             ItemsSource="{Binding CategoryOptions}"
                             SelectedItem="{Binding SelectedCategoryOption, Mode=TwoWay}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:CategoryOption}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock VerticalAlignment="Center"
                                               Foreground="White"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Text="{Binding Label}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="1"
                                               Margin="12,0,0,0"
                                               VerticalAlignment="Center"
                                               Foreground="#9CA3AF"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Text="{Binding Count}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Padding="16"
                    Background="#05080D"
                    BorderBrush="#121A27"
                    BorderThickness="1"
                    CornerRadius="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <DockPanel LastChildFill="True">
                            <TextBlock DockPanel.Dock="Left"
                                       Foreground="#64748B"
                                       FontSize="12"
                                       Text="{Binding StatusMessage}"
                                       TextWrapping="Wrap" />
                            <Border DockPanel.Dock="Right"
                                    Margin="16,0,0,0"
                                    Padding="12,7"
                                    Background="#04070C"
                                    BorderBrush="#1E293B"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <TextBlock Foreground="#22C3FF"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Text="{Binding ChannelCountText}" />
                            </Border>
                        </DockPanel>

                        <ProgressBar Margin="0,12,0,0"
                                     Height="5"
                                     Minimum="0"
                                     Maximum="100"
                                     Background="#111827"
                                     Foreground="#12B24A"
                                     IsIndeterminate="{Binding IsLoadProgressIndeterminate}"
                                     Value="{Binding LoadProgressValue}"
                                     Visibility="{Binding IsLoadProgressVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />

                        <TextBlock Margin="0,8,0,0"
                                   Foreground="#4B5563"
                                   FontSize="10"
                                   Text="{Binding LoadProgressText}"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding IsLoadProgressVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>

                    <Grid Grid.Row="1"
                          Margin="0,16,0,14"
                          Background="#05080D">
                        <TextBlock Margin="30"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="#64748B"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Text="{Binding ChannelListPlaceholderText}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding ShowChannelListPlaceholderText, Converter={StaticResource BooleanToVisibilityConverter}}" />

                        <ListBox x:Name="LiveChannelListBox"
                                 Loaded="ChannelGridListBox_Loaded"
                                 Unloaded="ChannelGridListBox_Unloaded"
                                 ItemsSource="{Binding ChannelsView}"
                                 SelectedItem="{Binding SelectedChannel, Mode=TwoWay}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="White"
                                 HorizontalContentAlignment="Stretch"
                                 ItemContainerStyle="{StaticResource LiveChannelListItemStyle}"
                                 ScrollViewer.CanContentScroll="True"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.ScrollUnit="Pixel"
                                 VirtualizingPanel.VirtualizationMode="Recycling"
                                 Visibility="{Binding ShowLiveChannelList, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:Channel}">
                                    <Grid Margin="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Border Width="60"
                                                Height="60"
                                                Background="#0F172A"
                                                BorderBrush="#1E293B"
                                                BorderThickness="1"
                                                CornerRadius="14"
                                                ClipToBounds="True">
                                            <Grid>
                                                <TextBlock HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="#475569"
                                                           FontSize="18"
                                                           FontWeight="Bold"
                                                           Text="TV" />
                                                <Image Source="{Binding PosterImageSource}"
                                                       Stretch="UniformToFill" />
                                            </Grid>
                                        </Border>

                                        <StackPanel Grid.Column="1"
                                                    Margin="14,0,12,0"
                                                    VerticalAlignment="Center">
                                            <DockPanel LastChildFill="True">
                                                <TextBlock Foreground="White"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding Name}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <CheckBox DockPanel.Dock="Right"
                                                          Margin="12,0,0,0"
                                                          Click="FavoriteToggle_Click"
                                                          Content="Fav"
                                                          Foreground="#CBD5E1"
                                                          FontSize="10"
                                                          FontWeight="SemiBold"
                                                          IsChecked="{Binding IsFavorite, Mode=TwoWay}" />
                                            </DockPanel>

                                            <TextBlock Margin="0,6,0,0"
                                                       Foreground="#CBD5E1"
                                                       FontSize="12"
                                                       Text="{Binding CardSubtitleText}"
                                                       TextTrimming="CharacterEllipsis" />

                                            <TextBlock Margin="0,3,0,0"
                                                       Foreground="#64748B"
                                                       FontSize="11"
                                                       Text="{Binding FullscreenGuideText}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Visibility="{Binding HasNextProgramme, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        </StackPanel>

                                        <Border Grid.Column="2"
                                                Padding="8,4"
                                                VerticalAlignment="Center"
                                                Background="#0E7490"
                                                CornerRadius="999">
                                            <TextBlock Foreground="White"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Text="LIVE" />
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <ListBox x:Name="ChannelGridListBox"
                                 Loaded="ChannelGridListBox_Loaded"
                                 Unloaded="ChannelGridListBox_Unloaded"
                                 ItemsSource="{Binding ChannelsView}"
                                 SelectedItem="{Binding SelectedChannel, Mode=TwoWay}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="White"
                                 HorizontalContentAlignment="Stretch"
                                 ItemContainerStyle="{StaticResource PosterTileListItemStyle}"
                                 ScrollViewer.CanContentScroll="False"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 Visibility="{Binding ShowPosterChannelGrid, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:Channel}">
                                    <Border Width="156"
                                            Height="244"
                                            Background="#04070C"
                                            BorderBrush="#0F172A"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            ClipToBounds="True">
                                        <Grid>
                                            <Border>
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#101826" Offset="0" />
                                                        <GradientStop Color="#04070C" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>

                                            <TextBlock HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="#475569"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Text="LADDAR"
                                                       TextAlignment="Center" />

                                            <Image Source="{Binding PosterImageSource}"
                                                   Stretch="UniformToFill" />

                                            <Border Background="#1E293B"
                                                    Opacity="0.14" />

                                            <Grid Margin="8">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="*" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <DockPanel LastChildFill="False">
                                                    <Border Padding="6,3"
                                                            Background="#0E7490"
                                                            CornerRadius="7">
                                                        <TextBlock Foreground="White"
                                                                   FontSize="9"
                                                                   FontWeight="SemiBold"
                                                                   Text="{Binding ContentTypeLabel}" />
                                                    </Border>

                                                    <CheckBox DockPanel.Dock="Right"
                                                              Click="FavoriteToggle_Click"
                                                              Content="Fav"
                                                              Foreground="#E2E8F0"
                                                              FontSize="9"
                                                              FontWeight="SemiBold"
                                                              IsChecked="{Binding IsFavorite, Mode=TwoWay}" />
                                                </DockPanel>

                                                <Border Grid.Row="2"
                                                        Padding="9,10"
                                                        Background="#D9070B10"
                                                        CornerRadius="8">
                                                    <StackPanel>
                                                        <TextBlock Foreground="White"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold"
                                                                   Text="{Binding Name}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Margin="0,5,0,0"
                                                                   Foreground="#CBD5E1"
                                                                   FontSize="10"
                                                                   Text="{Binding CardSubtitleText}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <ListBox x:Name="SeriesGridListBox"
                                 Loaded="ChannelGridListBox_Loaded"
                                 Unloaded="ChannelGridListBox_Unloaded"
                                 ItemsSource="{Binding SeriesGroups}"
                                 SelectedItem="{Binding SelectedSeriesGroup, Mode=TwoWay}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="White"
                                 HorizontalContentAlignment="Stretch"
                                 ItemContainerStyle="{StaticResource PosterTileListItemStyle}"
                                 ScrollViewer.CanContentScroll="False"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 Visibility="{Binding ShowSeriesOverviewGrid, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:SeriesGroupItem}">
                                    <Border Width="172"
                                            Height="258"
                                            Background="#04070C"
                                            BorderBrush="#0F172A"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            ClipToBounds="True">
                                        <Grid>
                                            <Border>
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#101826" Offset="0" />
                                                        <GradientStop Color="#04070C" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>

                                            <TextBlock HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="#475569"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Text="SERIE"
                                                       TextAlignment="Center" />

                                            <Image Source="{Binding RepresentativeChannel.PosterImageSource}"
                                                   Stretch="UniformToFill" />

                                            <Border Background="#1E293B"
                                                    Opacity="0.18" />

                                            <Grid Margin="8">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="*" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <Border Padding="6,3"
                                                        HorizontalAlignment="Left"
                                                        Background="#0E7490"
                                                        CornerRadius="7">
                                                    <TextBlock Foreground="White"
                                                               FontSize="9"
                                                               FontWeight="SemiBold"
                                                               Text="SERIE" />
                                                </Border>

                                                <Border Grid.Row="2"
                                                        Padding="9,10"
                                                        Background="#D9070B10"
                                                        CornerRadius="8">
                                                    <StackPanel>
                                                        <TextBlock Foreground="White"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold"
                                                                   Text="{Binding Title}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Margin="0,5,0,0"
                                                                   Foreground="#CBD5E1"
                                                                   FontSize="10"
                                                                   Text="{Binding SummaryText}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Grid Visibility="{Binding ShowSeriesDetailView, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <DockPanel Margin="0,0,0,16"
                                       LastChildFill="True">
                                <Button DockPanel.Dock="Left"
                                        MinWidth="92"
                                        Margin="0,0,12,0"
                                        Padding="14,9"
                                        Click="SeriesBack_Click"
                                        Content="Tillbaka" />
                                <StackPanel>
                                    <TextBlock Foreground="White"
                                               FontSize="28"
                                               FontWeight="SemiBold"
                                               Text="{Binding SeriesDetailTitle}" />
                                    <TextBlock Margin="0,5,0,0"
                                               Foreground="#64748B"
                                               FontSize="12"
                                               Text="{Binding SeriesDetailSubtitle}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </DockPanel>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Padding="14"
                                        Background="#04070C"
                                        BorderBrush="#182233"
                                        BorderThickness="1"
                                        CornerRadius="14">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Foreground="#CBD5E1"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Text="Säsonger" />

                                        <ListBox Grid.Row="1"
                                                 Margin="0,12,0,0"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 Foreground="White"
                                                 ItemContainerStyle="{StaticResource SidebarCategoryListItemStyle}"
                                                 ItemsSource="{Binding SelectedSeriesGroup.Seasons}"
                                                 SelectedItem="{Binding SelectedSeriesSeason, Mode=TwoWay}"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate DataType="{x:Type models:SeriesSeasonItem}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock VerticalAlignment="Center"
                                                                   Foreground="White"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   Text="{Binding Label}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <CheckBox Grid.Column="1"
                                                                  Margin="12,0,0,0"
                                                                  VerticalAlignment="Center"
                                                                  Click="SeriesSeasonFavoriteToggle_Click"
                                                                  Content="Fav"
                                                                  Foreground="#CBD5E1"
                                                                  FontSize="10"
                                                                  FontWeight="SemiBold"
                                                                  IsChecked="{Binding IsFavorite, Mode=TwoWay}" />
                                                        <TextBlock Grid.Column="2"
                                                                   Margin="12,0,0,0"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="#9CA3AF"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   Text="{Binding EpisodeCount}" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="2"
                                        Padding="14"
                                        Background="#04070C"
                                        BorderBrush="#182233"
                                        BorderThickness="1"
                                        CornerRadius="14">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Foreground="#CBD5E1"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding SelectedSeriesSeason.Label, TargetNullValue=Välj en säsong}" />

                                        <ListBox Grid.Row="1"
                                                 Margin="0,12,0,0"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 Foreground="White"
                                                 ItemsSource="{Binding CurrentSeriesEpisodes}"
                                                 ScrollViewer.CanContentScroll="True"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                 VirtualizingPanel.IsVirtualizing="True"
                                                 VirtualizingPanel.ScrollUnit="Pixel"
                                                 VirtualizingPanel.VirtualizationMode="Recycling">
                                            <ListBox.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <VirtualizingStackPanel />
                                                </ItemsPanelTemplate>
                                            </ListBox.ItemsPanel>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate DataType="{x:Type models:SeriesEpisodeItem}">
                                                    <Border Margin="0,0,0,10"
                                                            Padding="12"
                                                            Background="#09111E"
                                                            BorderBrush="#182233"
                                                            BorderThickness="1"
                                                            CornerRadius="12">
                                                        <DockPanel LastChildFill="True">
                                                            <Button DockPanel.Dock="Right"
                                                                    MinWidth="84"
                                                                    Margin="12,0,0,0"
                                                                    Padding="12,8"
                                                                    Click="SeriesEpisodePlay_Click"
                                                                    Content="Spela" />

                                                            <StackPanel>
                                                                <TextBlock Foreground="White"
                                                                           FontSize="13"
                                                                           FontWeight="SemiBold"
                                                                           Text="{Binding Title}"
                                                                           TextWrapping="Wrap" />
                                                                <TextBlock Margin="0,4,0,0"
                                                                           Foreground="#64748B"
                                                                           FontSize="11"
                                                                           Text="{Binding Subtitle}" />
                                                            </StackPanel>
                                                        </DockPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>

                        <Grid Panel.ZIndex="20"
                              Background="#C405080D"
                              Visibility="{Binding ShowGridLoadingOverlay, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <Grid Width="74"
                                      Height="74">
                                    <Ellipse Stroke="#1E293B"
                                             StrokeThickness="6" />
                                    <Ellipse Stroke="#38BDF8"
                                             StrokeDashArray="1.6 2.2"
                                             StrokeDashCap="Round"
                                             StrokeThickness="6"
                                             Style="{StaticResource SpinnerRotateStyle}" />
                                </Grid>
                                <TextBlock Margin="0,22,0,0"
                                           HorizontalAlignment="Center"
                                           Foreground="#F8FAFC"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Text="Laddar innehåll" />
                                <TextBlock Margin="0,10,0,0"
                                           HorizontalAlignment="Center"
                                           Foreground="#94A3B8"
                                           FontSize="12"
                                           Text="{Binding StatusMessage}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,6,0,0"
                                           HorizontalAlignment="Center"
                                           Foreground="#64748B"
                                           FontSize="11"
                                           Text="{Binding LoadProgressText}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <Border Grid.Row="2"
                            Padding="12"
                            Background="#04070C"
                            BorderBrush="#182233"
                            BorderThickness="1"
                            CornerRadius="14">
                        <DockPanel LastChildFill="True">
                            <TextBlock DockPanel.Dock="Left"
                                       Foreground="#64748B"
                                       FontSize="11"
                                       Text="{Binding ChannelSelectionHintText}" />
                            <TextBlock DockPanel.Dock="Right"
                                       Foreground="#CBD5E1"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Text="{Binding CurrentBrowserSelectionText}" />
                        </DockPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <TextBlock Grid.Row="3"
                   Margin="6,14,0,0"
                   Foreground="#4B5563"
                   FontSize="11"
                   Text="{Binding FavoritesStorageText}"
                   Visibility="{Binding ShowBrowserShell, Converter={StaticResource BooleanToVisibilityConverter}}" />

        <Grid Grid.RowSpan="4"
              Visibility="{Binding ShowDashboard, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="#08101F"
                    BorderBrush="#13223B"
                    BorderThickness="1"
                    CornerRadius="30">
                <Grid Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel LastChildFill="False">
                        <StackPanel DockPanel.Dock="Left">
                            <Border Padding="10,6"
                                    Background="#020617"
                                    BorderBrush="#334155"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <TextBlock Foreground="#F8FAFC"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           Text="PoePerfect Player" />
                            </Border>
                            <TextBlock Margin="0,10,0,0"
                                       Foreground="#64748B"
                                       FontSize="12"
                                       Text="{Binding DashboardHintText}" />
                        </StackPanel>

                        <Button DockPanel.Dock="Right"
                                Padding="18,10"
                                Background="#0F172A"
                                BorderBrush="#334155"
                                BorderThickness="1"
                                Click="OpenPlaylistEditor_Click"
                                Content="Playlists"
                                Foreground="#E2E8F0"
                                FontSize="12"
